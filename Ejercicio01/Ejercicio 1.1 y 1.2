miLength' :: [a] -> Int
miLength' = foldl (\acc _ -> acc + 1) 0 

miLast' :: [a] -> a
miLast' = foldl1 (\_ x -> x)

duplicar' :: [Int] -> [Int]
duplicar' = map (* 2) 

eliminarPares' :: [Int] -> [Int]
eliminarPares' = filter odd 
