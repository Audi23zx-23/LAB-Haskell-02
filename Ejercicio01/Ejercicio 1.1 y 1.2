miLenght :: [a] -> Int
miLenght [] = 0
miLenght (_:xs) = 1 + miLenght xs

miLast :: [a] -> a
miLast [x] = x
miLast (_:xs) = miLast xs

duplicar :: [Int] -> [Int]
duplicar [] = []
duplicar (x:xs) = x * 2 : duplicar xs

eliminarPares :: [Int] -> [Int]
eliminarPares [] = []
eliminarPares (x:xs)
    | even x = eliminarPares xs
    | otherwise = x : eliminarPares xs

